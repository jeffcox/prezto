# Messes with Slack to not be a lightbulb
# Requires a css file at the specified path
# Why are you using my fork?
#

gitrepo="/Users/jcox/src/slack-dark-mojave-theme/"

git -C $gitrepo pull

#quick and dirty hack to check if the file has been noodled with
if [[ $(tail -n 1 /Applications/Slack.app/Contents/Resources/app.asar.unpacked/src/static/ssb-interop.js) != "});" ]]; then
  # if not, noddle with it, as long as we can
  if [[ -w /Applications/Slack.app/Contents/Resources/app.asar.unpacked/src/static/ssb-interop.js ]]; then
    echo "document.addEventListener('DOMContentLoaded', function() {
  var fs = require('fs'),
  filePath = '/Users/jcox/src/slack-dark-mojave-theme/style.css';
  fs.readFile(filePath, {encoding: 'utf-8'}, function(err, data) {
    if (!err) {
      var css = document.createElement('style')
      css.innerText = data;
      document.getElementsByTagName('head')[0].appendChild(css);
    }
  })
});" >> /Applications/Slack.app/Contents/Resources/app.asar.unpacked/src/static/ssb-interop.js

  else
    echo "Can't write to ssb-interop.js"
  fi
else
  echo "ssb-interop.js looks good"
fi
